{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "prisma:generate": {
      "cache": false
    },
    "build:next": {
      "dependsOn": ["build", "prisma:generate"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "outputs": []
    },
    "lint:next": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:next": {
      "cache": false,
      "persistent": true
    },
    "//#dev:next": {
      "cache": false,
      "persistent": true
    },
    "//#start:next": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": ["coverage/**"]
    }
  }
}
